# Copy this file to .env and fill in local-only secrets there.

LEETANIM_LLM_API_KEY=
LEETANIM_LLM_MODEL=gpt-4.1-mini
LEETANIM_LLM_BASE_URL=https://api.openai.com/v1
LEETANIM_LLM_TEMPERATURE=0.7
LEETANIM_LLM_MAX_TOKENS=9000
LEETANIM_LLM_TIMEOUT_SEC=240
LEETANIM_LLM_MAX_RETRIES=3
LEETANIM_LLM_RETRY_BACKOFF_SEC=1.5
LEETANIM_LLM_MAX_CONTINUATIONS=5

LEETANIM_TARGET_DURATION_SEC=160

LEETANIM_MANIM_FONT=
LEETANIM_MANIM_MAX_TOKENS=2600

LEETANIM_VOICE=zh-CN-XiaoxiaoNeural
LEETANIM_RATE=+0%
LEETANIM_VOLUME=+0%
LEETANIM_PITCH=+0Hz
